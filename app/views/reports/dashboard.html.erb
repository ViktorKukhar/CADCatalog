<div class="container-fluid py-4">
  <div class="page-header mb-4">
    <h1>Analytics Dashboard</h1>
    <p class="text-muted">Comprehensive overview of your CAD catalog data</p>
  </div>

  <!-- Key Metrics Row -->
  <div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Records</h6>
          <h3 class="mb-0"><%= @summary[:records][:total] %></h3>
          <small class="text-success"><%= @summary[:records][:tagged_percentage] %>% Tagged</small>
        </div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Total Tags</h6>
          <h3 class="mb-0"><%= @summary[:tags][:total_tags] %></h3>
          <small class="text-info"><%= @summary[:tags][:avg_tags_per_record].round(2) %> per record</small>
        </div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Software Tools</h6>
          <h3 class="mb-0"><%= @summary[:software][:total_count] %></h3>
          <small class="text-warning">Avg Rating: <%= @summary[:software][:avg_rating] %></small>
        </div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="text-muted mb-2">Avg Complexity</h6>
          <h3 class="mb-0"><%= @summary[:complexity][:avg] %></h3>
          <small><%= link_to "View Distribution", reports_complexity_analysis_path %></small>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Data Section -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Top 5 Tags by Records</h5>
        </div>
        <div class="card-body">
          <% if @summary[:top_tags].any? %>
            <div class="list-group list-group-flush">
              <% @summary[:top_tags].each do |tag| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <span><%= tag[:name] %></span>
                  <span class="badge bg-primary"><%= tag[:count] %> records</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No tags yet</p>
          <% end %>
        </div>
        <div class="card-footer bg-light text-center">
          <%= link_to "View All Tags", reports_tags_analysis_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Top 5 Software by Usage</h5>
        </div>
        <div class="card-body">
          <% if @summary[:top_software].any? %>
            <div class="list-group list-group-flush">
              <% @summary[:top_software].each do |software| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <span><%= software[:name] %></span>
                  <span class="badge bg-success"><%= software[:count] %> uses</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No software data yet</p>
          <% end %>
        </div>
        <div class="card-footer bg-light text-center">
          <%= link_to "View All Software", reports_software_analysis_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Records & Contributors Section -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Well-Tagged Records</h5>
        </div>
        <div class="card-body">
          <% if @summary[:top_tagged_records].any? %>
            <div class="list-group list-group-flush">
              <% @summary[:top_tagged_records].each do |record| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <span><%= record[:title] %></span>
                  <span class="badge bg-info"><%= record[:tag_count] %> tags</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No records yet</p>
          <% end %>
        </div>
        <div class="card-footer bg-light text-center">
          <%= link_to "View Record Details", reports_records_analysis_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Top 5 Contributors</h5>
        </div>
        <div class="card-body">
          <% if @summary[:top_contributors].any? %>
            <div class="list-group list-group-flush">
              <% @summary[:top_contributors].each do |contributor| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <span><%= contributor[:name] %></span>
                  <span class="badge bg-warning"><%= contributor[:record_count] %> records</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No contributors yet</p>
          <% end %>
        </div>
        <div class="card-footer bg-light text-center">
          <%= link_to "View User Analysis", reports_user_analysis_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Complexity Distribution -->
  <div class="row mb-4">
    <div class="col-md-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Complexity Score Distribution</h5>
        </div>
        <div class="card-body">
          <% if @summary[:complexity][:distribution].any? %>
            <div class="row">
              <% @summary[:complexity][:distribution].each do |bucket| %>
                <div class="col-md-2 col-sm-4 mb-3 text-center">
                  <div class="complexity-bucket">
                    <h6><%= bucket[:range] %></h6>
                    <h4><%= bucket[:count] %></h4>
                    <p class="text-muted">records</p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No complexity data available</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Links to Detailed Reports -->
  <div class="row">
    <div class="col-md-12">
      <h5 class="mb-3">Detailed Analysis Reports</h5>
      <div class="d-flex flex-wrap gap-2">
        <%= link_to "Records Analysis", reports_records_analysis_path, class: "btn btn-outline-primary" %>
        <%= link_to "Software Analysis", reports_software_analysis_path, class: "btn btn-outline-success" %>
        <%= link_to "Tags Analysis", reports_tags_analysis_path, class: "btn btn-outline-info" %>
        <%= link_to "User Contributions", reports_user_analysis_path, class: "btn btn-outline-warning" %>
        <%= link_to "Complexity Analysis", reports_complexity_analysis_path, class: "btn btn-outline-danger" %>
        <%= link_to "Timeline Analysis", reports_timeline_analysis_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<style>
  .complexity-bucket {
    padding: 1rem;
    background-color: #f8f9fa;
    border-radius: 0.375rem;
    border: 1px solid #dee2e6;
  }

  .complexity-bucket h4 {
    color: #0d6efd;
    font-weight: 600;
  }

  .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15) !important;
  }

  .list-group-item {
    padding: 0.75rem 0;
  }
</style>
