<div class="container-fluid py-4">
  <div class="page-header mb-4">
    <h1>Records Analysis</h1>
    <p class="text-muted">Detailed analysis of your CAD records collection</p>
  </div>

  <!-- Statistics Cards -->
  <div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm bg-light">
        <div class="card-body">
          <h6 class="text-muted">Total Records</h6>
          <h3><%= @records_count[:total] %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm bg-light">
        <div class="card-body">
          <h6 class="text-muted">Tagged</h6>
          <h3><%= @records_count[:tagged] %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm bg-light">
        <div class="card-body">
          <h6 class="text-muted">Untagged</h6>
          <h3><%= @records_count[:untagged] %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
      <div class="card border-0 shadow-sm bg-light">
        <div class="card-body">
          <h6 class="text-muted">Tagged %</h6>
          <h3><%= @records_count[:tagged_percentage] %>%</h3>
        </div>
      </div>
    </div>
  </div>

  <!-- Dimensions Section -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Average Dimensions</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-6">
              <p class="text-muted">Average Width</p>
              <h4><%= @average_dimensions[:width] %> mm</h4>
            </div>
            <div class="col-6">
              <p class="text-muted">Average Height</p>
              <h4><%= @average_dimensions[:height] %> mm</h4>
            </div>
            <div class="col-12 mt-3">
              <p class="text-muted">Average Depth</p>
              <h4><%= @average_dimensions[:depth] %> mm</h4>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Dimension Ranges</h5>
        </div>
        <div class="card-body">
          <h6>Width Range</h6>
          <p><%= @dimension_range[:width][:min] %> - <%= @dimension_range[:width][:max] %> mm</p>

          <h6>Height Range</h6>
          <p><%= @dimension_range[:height][:min] %> - <%= @dimension_range[:height][:max] %> mm</p>

          <h6>Depth Range</h6>
          <p><%= @dimension_range[:depth][:min] %> - <%= @dimension_range[:depth][:max] %> mm</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Records by Tag -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Records by Tag</h5>
        </div>
        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
          <% if @records_by_tag.any? %>
            <div class="list-group list-group-flush">
              <% @records_by_tag.each do |tag| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <strong><%= tag[:name] %></strong>
                  <span class="badge bg-primary"><%= tag[:count] %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No tags available</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Records by User</h5>
        </div>
        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
          <% if @records_by_user.any? %>
            <div class="list-group list-group-flush">
              <% @records_by_user.each do |user| %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                  <strong><%= user[:name] %></strong>
                  <span class="badge bg-success"><%= user[:count] %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No user records</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Average Dimensions by Tag -->
  <div class="row mb-4">
    <div class="col-md-12 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Average Dimensions by Tag</h5>
        </div>
        <div class="card-body">
          <% if @average_dimensions_by_tag.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="table-light">
                  <tr>
                    <th>Tag</th>
                    <th>Avg Width (mm)</th>
                    <th>Avg Height (mm)</th>
                    <th>Avg Depth (mm)</th>
                    <th>Records</th>
                  </tr>
                </thead>
                <tbody>
                  <% @average_dimensions_by_tag.each do |tag| %>
                    <tr>
                      <td><strong><%= tag[:name] %></strong></td>
                      <td><%= tag[:width] %></td>
                      <td><%= tag[:height] %></td>
                      <td><%= tag[:depth] %></td>
                      <td><span class="badge bg-info"><%= tag[:count] %></span></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">No dimension data available</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Most and Least Tagged -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Most Tagged Records</h5>
        </div>
        <div class="card-body">
          <% if @most_tagged.any? %>
            <div class="list-group list-group-flush">
              <% @most_tagged.each do |record| %>
                <div class="list-group-item d-flex justify-content-between">
                  <span><%= record[:title] %></span>
                  <span class="badge bg-success"><%= record[:tag_count] %> tags</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No records</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Least Tagged Records (Data Quality)</h5>
        </div>
        <div class="card-body">
          <% if @least_tagged.any? %>
            <div class="list-group list-group-flush">
              <% @least_tagged.each do |record| %>
                <div class="list-group-item d-flex justify-content-between">
                  <span><%= record[:title] %></span>
                  <span class="badge bg-warning"><%= record[:tag_count] %> tags</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">All records well-tagged</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Back to Dashboard -->
  <div class="row">
    <div class="col-md-12">
      <%= link_to "← Back to Dashboard", reports_dashboard_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
</div>

<style>
  .table-hover tbody tr:hover {
    background-color: #f8f9fa;
  }

  .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15) !important;
  }
</style>
