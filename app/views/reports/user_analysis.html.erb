<div class="container-fluid py-4">
  <div class="page-header mb-4">
    <h1>User Contributions</h1>
    <p class="text-muted">Track user contributions and activity metrics</p>
  </div>

  <!-- User Statistics Table -->
  <div class="row mb-4">
    <div class="col-md-12 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">User Contribution Statistics</h5>
        </div>
        <div class="card-body">
          <% if @user_stats.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="table-light">
                  <tr>
                    <th>User</th>
                    <th>Records Created</th>
                    <th>Avg Complexity</th>
                    <th>Max Complexity</th>
                  </tr>
                </thead>
                <tbody>
                  <% @user_stats.each do |user| %>
                    <tr>
                      <td><strong><%= user[:name] %></strong></td>
                      <td><span class="badge bg-primary"><%= user[:record_count] %></span></td>
                      <td><%= user[:avg_complexity] %></td>
                      <td><span class="badge bg-info"><%= user[:max_complexity] %></span></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">No user data available</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Records by User Breakdown -->
  <div class="row mb-4">
    <div class="col-md-12 mb-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">Records by User</h5>
        </div>
        <div class="card-body">
          <% if @user_records_count.any? %>
            <div class="row">
              <% @user_records_count.each do |user| %>
                <div class="col-md-6 mb-3">
                  <div class="user-contribution-card p-3 border rounded">
                    <h6><%= user[:name] %></h6>
                    <h4 class="text-primary"><%= user[:count] %> records</h4>
                    <div class="progress" style="height: 6px;">
                      <div class="progress-bar" style="width: <%= (user[:count].to_f / (@user_records_count.map { |u| u[:count] }.max || 1)) * 100 %>%"></div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No users have created records</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Back to Dashboard -->
  <div class="row">
    <div class="col-md-12">
      <%= link_to "← Back to Dashboard", reports_dashboard_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
</div>

<style>
  .user-contribution-card {
    background-color: #f8f9fa;
    transition: all 0.2s ease;
  }

  .user-contribution-card:hover {
    background-color: #e9ecef;
    transform: translateX(4px);
  }

  .table-hover tbody tr:hover {
    background-color: #f8f9fa;
  }

  .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15) !important;
  }
</style>
