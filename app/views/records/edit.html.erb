<!-- Page Navigation Context -->
<div class="breadcrumb-section bg-light py-2 mb-4">
  <div class="container">
    <% builder = NavigationBuilder.new(current_user, request) %>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><%= link_to 'Home', root_path %></li>
        <li class="breadcrumb-item"><%= link_to 'Records', records_path %></li>
        <li class="breadcrumb-item"><%= link_to @record.title, record_path(@record) %></li>
        <li class="breadcrumb-item active">Edit</li>
      </ol>
    </nav>
  </div>
</div>

<div class="py-5 text-center container">
  <h2>Edit Record:</h2>
  <p class="lead">Update the record details, files, and metadata below.</p>
</div>

<%= render "records/partials/form", record: @record %>

<div class="container mt-4">
  <%= link_to 'Back to Record', record_path(@record), class: 'btn btn-secondary' %>
</div>
