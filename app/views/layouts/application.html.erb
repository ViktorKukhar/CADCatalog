<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>CadCatalog</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= render "shared/header" %>
    
    <div class="container-fluid main-content">
      <div class="row">
        <!-- Sidebar Navigation for filtered views -->
        <% if controller_name == 'records' %>
          <aside class="col-md-3 col-lg-2 d-md-block bg-light sidebar">
            <nav class="category-nav pt-3">
              <h5 class="px-3">Categories</h5>
              <ul class="nav flex-column">
                <li class="nav-item">
                  <%= link_to 'All Records', records_path, class: 'nav-link' %>
                </li>
                <li class="nav-item">
                  <%= link_to 'My Records', records_path(filter: 'my'), class: 'nav-link' %>
                </li>
              </ul>
              
              <h5 class="px-3 mt-4">Tags</h5>
              <ul class="nav flex-column">
                <% Tag.limit(10).each do |tag| %>
                  <li class="nav-item">
                    <%= link_to tag.name, records_path(tag: tag.name), class: 'nav-link' %>
                  </li>
                <% end %>
              </ul>
            </nav>
          </aside>
        <% end %>
        
        <!-- Main Content Area -->
        <main class="<%= controller_name == 'records' ? 'col-md-9 col-lg-10' : 'col-12' %> ms-sm-auto px-md-4">
          <%= yield %>
        </main>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <p class="notice"><%= notice %></p>
    <p class="alert"><%= alert %></p>
    <%= render "shared/footer" %>
  </body>
</html>
